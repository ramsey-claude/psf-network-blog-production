<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.psfnetwork.stage10</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/onur/psfnetwork-pipeline/.venv/bin/python3</string>
        <string>/Users/onur/psfnetwork-pipeline/workflow/stage10_runner.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/onur/psfnetwork-pipeline</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PSFNETWORK_GITHUB_TOKEN_FILE</key>
        <string>/Users/onur/.psfnetwork-drive/github-token</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/local/bin</string>
    </dict>

    <!-- Run once per day at 09:13 local time. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>13</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/onur/.psfnetwork-drive/stage10.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/onur/.psfnetwork-drive/stage10.err</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
