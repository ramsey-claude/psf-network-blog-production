#!/usr/bin/env bash
# psfnetwork pre-commit hook
#
# Blocks commits that violate Tier 0 (BLOCKING) rules from checklist/ai-tells.md.
# Scope: every staged .md file (blog content, checklists, workflow specs,
# brand docs, README, ROADMAP). Same rules apply to every file.
#
# Activate locally:
#   git config core.hooksPath .githooks
#
# Bypass (do not, this exists because we kept violating the rule):
#   git commit --no-verify
#
# BSD-grep compatible (macOS default). Uses LC_ALL=C, grep -F for literal
# unicode punctuation, and BRE patterns ('^[+]' instead of '^\+') to avoid
# BSD ERE issues with backslash-plus.

set -uo pipefail

STAGED_MD=$(git diff --cached --name-only --diff-filter=AM | grep '\.md$' || true)

if [ -z "$STAGED_MD" ]; then
    exit 0
fi

FAIL=0

# scan_fixed pattern label severity
# Fixed-string match. Use for unicode punctuation and exact phrases.
scan_fixed() {
    local pattern="$1"
    local label="$2"
    local severity="$3"
    local total=0
    local f hits
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        hits=$(git diff --cached -U0 -- "$f" 2>/dev/null \
            | grep '^[+]' 2>/dev/null \
            | grep -v '^[+][+][+]' 2>/dev/null \
            | LC_ALL=C grep -cF -- "$pattern" 2>/dev/null || true)
        hits=${hits:-0}
        if [ "$hits" -gt 0 ] 2>/dev/null; then
            printf '  [%s] %s in %s (%s new occurrences)\n' "$severity" "$label" "$f" "$hits" >&2
            total=$((total + hits))
        fi
    done <<< "$STAGED_MD"
    if [ "$total" -gt 0 ] && [ "$severity" = "BLOCK" ]; then
        FAIL=1
    fi
}

# scan_ere pattern label severity
# Extended-regex match. No \b (BSD does not support); use ( |^) and edge chars.
scan_ere() {
    local pattern="$1"
    local label="$2"
    local severity="$3"
    local total=0
    local f hits
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        hits=$(git diff --cached -U0 -- "$f" 2>/dev/null \
            | grep '^[+]' 2>/dev/null \
            | grep -v '^[+][+][+]' 2>/dev/null \
            | LC_ALL=C grep -cE -- "$pattern" 2>/dev/null || true)
        hits=${hits:-0}
        if [ "$hits" -gt 0 ] 2>/dev/null; then
            printf '  [%s] %s in %s (%s new occurrences)\n' "$severity" "$label" "$f" "$hits" >&2
            total=$((total + hits))
        fi
    done <<< "$STAGED_MD"
    if [ "$total" -gt 0 ] && [ "$severity" = "BLOCK" ]; then
        FAIL=1
    fi
}

# Tier 0: BLOCKING punctuation
scan_fixed '—' 'em-dash' 'BLOCK'
scan_fixed '–' 'en-dash' 'BLOCK'

# Tier 2: HIGH brand voice violations
scan_ere 'guaranteed (return|yield|annual)' 'guaranteed return language' 'BLOCK'
scan_ere 'PSFnetwork|PSF Network|PSFNETWORK|Psfnetwork' 'psfnetwork casing violation' 'BLOCK'

# Tier 2 HIGH AI tells (WARN only)
scan_ere '( |^)(unlock|leverage|leverages|leveraging|leveraged|robust|seamless|streamlined|synergy|harness|empower|myriad|plethora)( |[.,;:!?)"])' 'HIGH-tier AI tell' 'WARN'

if [ "$FAIL" -eq 1 ]; then
    printf '\nCommit refused. Fix BLOCK-tier issues above, then re-stage and commit.\n' >&2
    printf 'See checklist/ai-tells.md for replacement patterns.\n' >&2
    printf 'Bypass with --no-verify only in genuine emergencies; record the reason in the commit message.\n' >&2
    exit 1
fi

exit 0
